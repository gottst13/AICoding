<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.smartparking.userservice.mapper.UserMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.smartparking.userservice.entity.User">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="nickname" property="nickname"/>
        <result column="phone" property="phone"/>
        <result column="email" property="email"/>
        <result column="avatar_url" property="avatarUrl"/>
        <result column="wechat_openid" property="wechatOpenid"/>
        <result column="status" property="status"/>
        <result column="last_login_at" property="lastLoginAt"/>
        <result column="last_login_ip" property="lastLoginIp"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <!-- 基础列 -->
    <sql id="Base_Column_List">
        id, username, nickname, phone, email, avatar_url, wechat_openid, 
        status, last_login_at, last_login_ip, created_at, updated_at
    </sql>

    <!-- 根据用户名查询 -->
    <select id="findByUsername" resultMap="BaseResultMap" parameterType="string">
        SELECT
            <include refid="Base_Column_List"/>
        FROM users
        WHERE username = #{username}
        AND deleted = 0
    </select>

    <!-- 根据微信 OpenID 查询 -->
    <select id="findByWechatOpenid" resultMap="BaseResultMap" parameterType="string">
        SELECT
            <include refid="Base_Column_List"/>
        FROM users
        WHERE wechat_openid = #{wechatOpenid}
        AND deleted = 0
    </select>

</mapper>
